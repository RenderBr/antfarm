{
  "name": "neural-ant-farm",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build:css": "bunx --bun @tailwindcss/cli -i ./src/input.css -o ./dist/app.css --minify",
    "watch:css": "bunx --bun @tailwindcss/cli -i ./src/input.css -o ./dist/app.css --watch",
    "build:js": "bun build ./src/main.ts --outfile ./dist/app.js --minify",
    "watch:js": "bun build ./src/main.ts --outfile ./dist/app.js --watch",
    "build": "bun run build:js && bun run build:css",
    "watch": "bun run build:js -- --watch & bun run watch:css",
    "dev": "bun run build && bun ./serve.ts",
    "serve": "bun ./serve.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}